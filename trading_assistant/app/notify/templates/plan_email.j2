<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 800px; margin: 0 auto; padding: 20px; }
        .header { background: #0066cc; color: white; padding: 20px; border-radius: 5px; }
        .content { padding: 20px 0; }
        .trade { background: #f5f5f5; padding: 15px; margin: 10px 0; border-left: 4px solid #0066cc; }
        .trade-header { font-weight: bold; font-size: 1.1em; margin-bottom: 10px; }
        .metric { display: inline-block; margin-right: 20px; }
        .label { font-weight: bold; color: #666; }
        .value { color: #000; }
        .rules { background: #fff3cd; padding: 15px; margin: 20px 0; border-left: 4px solid #ffc107; }
        .footer { margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; font-size: 0.9em; color: #666; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📈 Premarket Trading Plan</h1>
            <p>Date: {{ plan.plan_date }}</p>
            <p>Generated: {{ plan.generated_at }}</p>
        </div>
        
        <div class="content">
            <h2>Top Trade Opportunities</h2>
            
            {% if plan.trades %}
                {% for trade in plan.trades %}
                <div class="trade">
                    <div class="trade-header">
                        #{{ trade.rank }} - {{ trade.symbol }}
                    </div>
                    
                    <div class="metric">
                        <span class="label">Entry:</span>
                        <span class="value">{{ "%.2f"|format(trade.entry_price) }}</span>
                    </div>
                    
                    <div class="metric">
                        <span class="label">Stop:</span>
                        <span class="value">{{ "%.2f"|format(trade.stop_price) }}</span>
                    </div>
                    
                    <div class="metric">
                        <span class="label">Target:</span>
                        <span class="value">{{ "%.2f"|format(trade.target_price) }}</span>
                    </div>
                    
                    <div class="metric">
                        <span class="label">Size:</span>
                        <span class="value">{{ trade.size_shares }} shares</span>
                    </div>
                    
                    <div style="margin-top: 10px;">
                        <div class="metric">
                            <span class="label">Score:</span>
                            <span class="value">{{ "%.2f"|format(trade.score_rank) }}</span>
                        </div>
                        
                        <div class="metric">
                            <span class="label">Confidence:</span>
                            <span class="value">{{ "%.1f%%"|format(trade.confidence * 100) }}</span>
                        </div>
                        
                        <div class="metric">
                            <span class="label">Failure Prob:</span>
                            <span class="value">{{ "%.1f%%"|format(trade.p_fail * 100) }}</span>
                        </div>
                    </div>
                    
                    {% if trade.trigger_json %}
                    <div style="margin-top: 10px;">
                        <span class="label">Trigger:</span>
                        <span class="value">{{ trade.trigger_json.description }}</span>
                    </div>
                    {% endif %}
                </div>
                {% endfor %}
            {% else %}
                <p>No trade opportunities identified for today.</p>
            {% endif %}
            
            <div class="rules">
                <h3>⚠️ Do Not Trade If:</h3>
                <ul>
                    <li>Daily loss limit reached: {{ plan.risk_limits.max_daily_loss }}</li>
                    <li>Gross exposure exceeds: {{ plan.risk_limits.max_gross_exposure }}</li>
                    <li>Market regime shows high volatility</li>
                    <li>News shock detected for the symbol</li>
                    <li>Liquidity below minimum ADV threshold</li>
                    <li>Spread exceeds {{ plan.risk_limits.max_spread_bps }} bps</li>
                </ul>
            </div>
            
            <div style="margin-top: 20px;">
                <h3>Portfolio Status</h3>
                <p><strong>Current Equity:</strong> {{ plan.portfolio.equity_base }}</p>
                <p><strong>Available for Trading:</strong> {{ plan.portfolio.available_capital }}</p>
                <p><strong>Current Positions:</strong> {{ plan.portfolio.num_positions }}</p>
            </div>
        </div>
        
        <div class="footer">
            <p>This is an automated trading plan. Review all trades carefully before execution.</p>
            <p>⚠️ This system is for research purposes only. Not financial advice.</p>
        </div>
    </div>
</body>
</html>
